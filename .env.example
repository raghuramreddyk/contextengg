# ─── LLM Provider ────────────────────────────────────────────────────────────
# Options: "ollama" | "openai" | "azure"
LLM_PROVIDER=ollama

# Ollama (local — no API key required)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ─── Embedding Model ──────────────────────────────────────────────────────────
# Used for ChromaDB semantic retrieval
# Options: "ollama" | "openai"
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─── Context Engine ───────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
CONTEXT_COLLECTION_NAME=domain_context
TOP_K_CONTEXT=5

# ─── Actor-Critic ─────────────────────────────────────────────────────────────
# Confidence thresholds for tiering (0.0–1.0)
CONFIDENCE_HIGH=0.85
CONFIDENCE_MEDIUM=0.60

# ─── HITL Gateway ─────────────────────────────────────────────────────────────
# "sync"  → LangGraph interrupt() – pauses graph for human input (CLI/notebook)
# "async" → queues review; resumed via POST /hitl/decision
HITL_MODE=sync

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── LangSmith Tracing (optional) ────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=contextengg
